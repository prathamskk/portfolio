---
import { Image } from 'astro:assets';
import svgUnderline from '../../assets/underline.svg'

import imgSenseLogo from '../../assets/company/sense-worldwide.jpg';
import imgBiaLogo from '../../assets/company/boston-institute-of-analytics.jpg';
import imgInspirusLogo from '../../assets/company/inspirus-education.jpg';
import imgEcellLogo from '../../assets/company/ecell-logo.png';
import imgUCLLogo from '../../assets/company/ucl_school_of_management_logo.jpg';

const experiences = [
  {
    company: 'Sense Worldwide',
    role: 'Msc Dissertation',
    period: 'Apr 2025 – Aug 2025',
    location: 'London',
    logo: imgSenseLogo,
    description:
      'Performed report development and dashboard building on Looker Studio, querying complex social media data on BigQuery to extract consumer insights, using a data-driven approach.',
    }, 
  {
    company: 'UCL',
    role: 'Data Engineering',
    period: 'Jan 2025 – Mar 2025',
    location: 'London',
    logo: imgUCLLogo,
    description:
      'Developed skills in the application of software engineering for managing and extracting value from large data sets.'
  },
  {
    company: 'UCL',
    role: 'Marketing Analytics',
    period: 'Sep 2024 – Dec 2024',
    location: 'London',
    logo: imgUCLLogo,
    description:
      'Mastered profitability analysis and causal inference tools to evaluate campaign effectiveness and measure causal effects of marketing initiatives' 
  },
  {
    company: 'Boston Institute of Analytics',
    role: 'Digital Marketing Intern',
    period: 'Sep 2022 – Feb 2023',
    location: 'Mumbai',
    logo: imgBiaLogo,
    description:
      'Executed Meta ads, utilizing specific audience segments and optimized ad copy to maximize lead generation, and customer acquisition.',
  },
]
---

<section class="py-20 space-y-10 px-5" id="experience">
  <div class="max-w-md mx-auto relative">
    <h1 class="text-4xl font-medium text-center">experience.</h1>
    <img src={svgUnderline.src} alt="underline" width="140" class="absolute left-35 -bottom-2" />
  </div>

  <div class="max-w-4xl mx-auto relative">
    <div class="pointer-events-none absolute left-6 top-0 bottom-0 w-[2px] bg-black md:left-8"></div>

    <div class="space-y-8 relative">
      {experiences.map((item) => (
        <div class="border-2 bg-white p-4 md:p-6 flex gap-4 md:gap-6 items-start relative">
          <div class="w-12 h-12 md:w-14 md:h-14 overflow-hidden border-2 bg-black flex items-center justify-center shrink-0">
            <Image src={item.logo} alt={`${item.company} logo`} width={56} height={56} class="w-full h-full object-contain" />
          </div>
          <div class="space-y-2">
            <h2 class="text-xl font-medium">
              {item.company} - {item.role}
            </h2>
            <p class="text-xs uppercase tracking-wide text-gray-500">
              {item.period} · {item.location}
            </p>
            <p class="text-base">
              {item.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
