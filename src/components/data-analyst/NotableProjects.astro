---
import { Image } from "astro:assets";
import svgUnderline from "../../assets/underline.svg";
import svgLeetcode from "../../assets/logos/leetcode.svg";
import imgSQL50Achievement from "../../assets/leetcode_sql_50_banner.png";
import imgEcellLogo from "../../assets/company/ecell-logo.png";
import imgZaikaWebsite from "../../assets/projects/zaika/zaika_website.jpg";
import imgZaikaTeaser from "../../assets/projects/zaika/zaika_teaser.jpg";
import imgZaikaUsage from "../../assets/projects/zaika/zaika_usage_thumbnail.jpg";
import imgBiaLogo from "../../assets/company/boston-institute-of-analytics.jpg";
import imgBiaMockup from "../../assets/BIA_marketing_mockup.png";
import imgSenseLogo from "../../assets/company/sense-worldwide.jpg";
import imgSlidesMockup from "../../assets/social-listening-tool-slides-mockup.png";
import imgSlListeningDiagram from "../../assets/social_listening_diagram.png";
import imgDataIntegrationSocial from "../../assets/data_integration_social.png";
import imgDashboardSocialListening from "../../assets/dashboard_development_social_listening.png";
import imgInspirusLogo from "../../assets/company/inspirus-education.jpg";
import imgAmazonPrimeLogo from "../../assets/logos/amazon_prime_logo.jpg";
import imgInspirusMockup from "../../assets/inspirus-website-mockup.png";
import imgLearnsbarMockup from "../../assets/learnsbar-mockup.png";
import imgLearnsbar1 from "../../assets/learnsbar-image-1.png";
import imgLearnsbar2 from "../../assets/learnsbar-image-2.png";
import imgMarketingVenn from "../../assets/marketing-analytics-venn.png";
import imgRStudioMockup from "../../assets/r_studio_mockup.png";
import imgROIComparison from "../../assets/predictive_modelling_marketing_roi_comparison.png";
import imgPredictiveModelling from "../../assets/predictive_modelling.png";
import imgLeetcodeList from "../../assets/leetcode_solved_list.png";
import imgLeetcodeSolutions from "../../assets/leetcode_sql_50_problem_solution.png";

const base = import.meta.env.BASE_URL;

const ecell = {
  title: "Digital Content & Social Media",
  summary:
    "E-Cell SAKEC is a student-led nonprofit organisation promoting entrepreneurship among students. In this role, I developed and launched digital content strategies for multiple events (Project Pillar, Food Fiesta), helping to establish our organisation's digital presence and expand awareness.",
  objectives:
    "Led end-to-end web content management, including content production, website administration, search engine optimisation (SEO), and performance tracking to drive brand awareness and engagement.",
  impact: [
    { label: "Attendees Gathered", value: "600+", icon: "👥" },
    { label: "Organic Search Ranking", value: "Page 1", icon: "📈" },
    { label: "Digital Formats Launched", value: "3+", icon: "🎬" },
    { label: "Digital Presence Established", value: "100%", icon: "✅" },
  ],
  image: imgZaikaWebsite,
};

const content_creation = {
  title: "Content Creation",
  summary:
    "Beyond digital content strategy, I actively supported a range of content creation activities, including editing videos, graphic design, and branding to increase social media engagement and reach, ultimately optimising event participation.",
  assets: {
    howTo: {
      label: "How-to app walkthrough",
      src: "projects/zaika/zaika_how_to_app.mp4",
    },
    teaser: {
      label: "Fast-paced promotional teaser edit for social media.",
      file: "zaika_teaser.jpg",
    },
    usage: {
      label: "Usage thumbnail for in-app ordering journey.",
      file: "zaika_usage_thumbnail.jpg",
    },
    websiteLive: { label: "Website is live", file: "website_is_live.webp" },
    uiVideo: {
      label: "Step-by-step instructional UI video for user onboarding.",
      src: "projects/ff/live_now.mp4",
    },
  },
};

const bia = {
  title: "Digital Advertising & Marketing Campaign",
  summary:
    "Boston Institute of Analytics is a training institute specializing in data science. In this role, I managed the digital lead generation strategy for their Mumbai branch, focusing on filling enrollment quotas for their first technical program batch.",
  objectives:
    "Developed a targeted ads marketing strategy by levaraging META ads. I optimized audience targeting, ad creatives, and budget allocation to generate qualified leads and maximize conversations.",
  scope: [
    "Ads Strategy and Optimization",
    "Visual Ad Content",
    "Campaign Execution and Management",
    "Analytics and Performance Optimziation",
  ],
  strategy: [
    "Monitored Ad performance through key metrics (CTR, CPC, Conversion rates)",
    "Optimized ad placements and budget allocation for better ROI.",
  ],
  result: ["✅ Enrollment quota fulfilled - 100% ", "✅ Fully booked cohort "],
  image: imgBiaMockup,
  logo: imgBiaLogo,
};

const leetcode = {
  title: "SQL Querying",
  summary:
    "Leetcode is a popular online platform primarily used by software developers to enhance their coding skills. I solved the SQL 50 Track on the platform. This track encompasses 50 real-world business scenarios, challenging me to write scalable SQL scripts to extract, manipulate, and analyze relational data.",
  context:
    "The platform offers performance insights and lets you compare your approach with other users' solutions",
};

const senseworldwide = {
  title: "Data Integration, Dashboard Building and Storytelling",
  summary:
    "Sense Worldwide is a strategic innovation consultancy based in London. As part of my MSc Dissertation project I collaborated with them. I transformed raw social media data into actionable insights, helping stakeholders understand market trends and user needs.",
  strategy:
    "Leveraged SQL, integrated disparate data sources and applied data transformation to prepare datasets ready for data analysis and dashboards",
  dashboard:
    "Developed interactive Looker BI dashboard and visualization to analyze consumer sentiment and brand perception, providing stakeholders with an intuitive interface to track KPIs and market trends",
  storytelling:
    "I translated complex analytical models into compelling visual narratives, bridging the gap between technical data engineering and executive decision-making.",
  image: imgSlidesMockup,
  logo: imgSenseLogo,
};

const predictive = {
  title: "Predictive Modelling & ROI Analysis",
  summary:
    "As part of the Marketing Analytics module at UCL, I solved a case study about a new Black Friday Amazon Prime marketing campaign. I applied statistical modelling techniques to predict customer behaviour and ROI analysis to assess acquistion efforts.",
  strategy:
    "I identified high value customers whose conversion likelihood exceeds break-even response rate through predictive modeling on customer dataset",
  modelling:
    "I compared different targeting strategies based on their projected Return on Investment (ROI) to recommend the most profitable path forward",
  image: imgSlidesMockup,
  logo: imgAmazonPrimeLogo,
};

const inspirus = {
  title: "Website Design and SEO",
  summary:
    "Inspirus Education is an overseas higher-education coaching and test-prep institute in Mumbai. I developed the company's website, ensuring it was fast, responsive and optimised for organic growth.",
  objectives:
    "Developed 9 pages on WordPress with customized themes, blogs and form integrations. I also handled technical SEO and website optimization",

  scope: [
    "Website Design",
    "Technical SEO",
    "Plugins integration",
    "Website Security",
  ],

  image: imgInspirusMockup,
  logo: imgInspirusLogo,
};

const learnsbar = {
  title: "UX Design",
  summary:
    "UI/UX mockups and user flows for an app built as part of an undergrad group project. Focused on clarity and usability.",
  objectives: "",
  image: imgLearnsbarMockup,
};

const marketing_analytics = {
  title: "Marketing Analytics (UCL)",
  summary:
    "This is a module that I studied in my Business Analytics MSc at UCL. Here I learnt how to utilise R programming, machine learning, and causal inference to guide marketing tactics and strategies in a scientific manner.",
  topics: [
    "Profitability Analysis",
    "Data Wrangling in R",
    "Customer Segmentation",
    "Customer Lifetime Value (CLV)",
    "Predictive Modelling",
    "Causal Inference (RDD, DiD, & IV)",
  ],
  results: [
    {
      assessment: "Retail Strategy Case Study",
      focus: "CAC, CLV",
      score: "71/100",
      grade: "✅ Distinction",
    },
    {
      assessment: "Amazon Prime Case Study",
      focus: "Predictive Modelling",
      score: "74/100",
      grade: "✅ Distinction",
    },
    {
      assessment: "Amazon TV Sales Case Study",
      focus: "MMM & Brand Equity",
      score: "75/100",
      grade: "✅ Distinction",
    },
    {
      assessment: "Overall module",
      focus: "",
      score: "73.33/100",
      grade: "✅ Distinction",
    },
  ],
  image: imgRStudioMockup,
};
---

<section class="py-20 px-5" id="notable-projects">
  <div class="max-w-md mx-auto mb-10 relative">
    <h1 class="text-4xl font-medium text-center">notable projects.</h1>
    <img
      src={svgUnderline.src}
      alt="underline"
      width="140"
      class="absolute left-35 -bottom-2"
    />
  </div>

  <div
    class="max-w-5xl mx-auto border-2 border-black bg-white shadow-[8px_8px_0_rgba(0,0,0,0.3)] p-6 space-y-8"
  >
    <!-- Sense Worldwide: overlapping layout, no tilt, original ratios -->
    <div class="space-y-6">
      <div class="space-y-4">
        <h2 class="text-2xl sm:text-3xl font-medium leading-tight">
          {senseworldwide.title}
        </h2>
        <div>
          <div
            class="float-left mr-4 w-20 h-20 sm:w-24 sm:h-24 border-2 border-black bg-white flex items-center justify-center overflow-hidden"
          >
            <Image
              src={imgSenseLogo}
              alt=""
              width={96}
              height={96}
              class="w-full h-full object-contain"
            />
          </div>
          <p class="text-sm sm:text-base leading-relaxed">
            {senseworldwide.summary}
          </p>
          <div class="clear-both"></div>
        </div>
      </div>

      <div class="space-y-2">
        <h3 class="text-lg font-semibold">Strategy</h3>
        <p class="space-y-1 text-sm">{senseworldwide.strategy}</p>
      </div>

      <div class="w-full flex items-center justify-center overflow-hidden">
        <Image
          src={imgDataIntegrationSocial}
          alt="Data integration workflow: Reddit and Quora data unified via SQL into a single analysis-ready view"
          class="w-full h-auto object-contain"
        />
      </div>

      <div class="space-y-2">
        <p class="space-y-1 text-sm">{senseworldwide.dashboard}</p>
      </div>
      <div class="w-full flex items-center justify-center overflow-hidden">
        <Image
          src={imgDashboardSocialListening}
          alt="Social listening dashboard: database schema, topic map, sentiment distribution and run summary"
          class="w-full h-auto object-contain"
        />
      </div>

      <div class="space-y-1">
        <p class="space-y-1 text-sm">{senseworldwide.storytelling}</p>
      </div>

      <div class="w-full flex items-center justify-center overflow-hidden">
        <Image
          src={imgSlidesMockup}
          alt="Social listening tool mockup and slide overview"
          class="w-full h-auto object-contain"
        />
      </div>
    </div>

    <div class="my-4 h-px bg-black/15"></div>

    <!-- Predictive Modelling - Marketing Analytics UCL -->
    <div class="space-y-6">
      <div class="space-y-4">
        <h2 class="text-2xl sm:text-3xl font-medium leading-tight">
          {predictive.title}
        </h2>
        <div>
          <div
            class="float-left mr-4 w-20 h-20 sm:w-24 sm:h-24 border-2 border-black bg-white flex items-center justify-center overflow-hidden"
          >
            <Image
              src={imgAmazonPrimeLogo}
              alt=""
              width={96}
              height={96}
              class="w-full h-full object-contain"
            />
          </div>
          <p class="text-sm sm:text-base leading-relaxed">
            {predictive.summary}
          </p>

          <div class="clear-both"></div>
        </div>
      </div>
      <div class="space-y-2">
        <h3 class="text-lg font-semibold">Strategy</h3>
        <p class="space-y-1 text-sm">{predictive.strategy}</p>
      </div>
      <div class="w-full flex items-center justify-center overflow-hidden">
        <Image
          src={imgPredictiveModelling}
          alt="Social listening tool mockup and slide overview"
          class="w-full h-auto object-contain"
        />
      </div>

      <div class="space-y-2">
        <p class="space-y-1 text-sm">{predictive.modelling}</p>
      </div>

      <div
        class="w-full flex items-center justify-center overflow-hidden mt-4 border-2 border-black bg-white px-3 py-1.5 text-sm shadow-[3px_3px_0_rgba(0,0,0,0.2)]"
      >
        <Image
          src={imgROIComparison}
          alt="Social listening diagram combining phones, data table, and charts"
          class="w-full h-auto object-contain"
        />
      </div>
    </div>

    <div class="my-4 h-px bg-black/15"></div>

    <!-- Leetcode -->
    <div class="space-y-6">
      <div class="space-y-4">
        <h2 class="text-2xl sm:text-3xl font-medium leading-tight">
          {leetcode.title}
        </h2>
        <div>
          <div
            class="float-left mr-4 w-20 h-20 sm:w-24 sm:h-24 border-2 border-black bg-white flex items-center justify-center overflow-hidden"
          >
            <Image
              src={svgLeetcode}
              alt=""
              width={96}
              height={96}
              class="w-full h-full object-contain p-2"
            />
          </div>
          <p class="text-sm sm:text-base leading-relaxed">{leetcode.summary}</p>
          <div class="clear-both"></div>
        </div>
      </div>
      <div class="flex flex-col gap-6">
        <div class="space-y-2">
          <p class="space-y-1 text-sm">{leetcode.context}</p>
        </div>
      </div>

      <div
        class="bg-white overflow-hidden min-h-0 flex items-center justify-center"
      >
        <Image
          src={imgLeetcodeSolutions}
          alt="BIA digital marketing mockup: Meta Ads Manager and Instagram ad creatives"
          class="w-full h-auto object-contain"
        />
      </div>

      <div class="grid grid-cols-[2fr_2fr] gap-6 items-start">
        <div class="min-h-0 flex items-center justify-center">
          <Image
            src={imgLeetcodeList}
            alt="BIA digital marketing mockup: Meta Ads Manager and Instagram ad creatives"
            class="w-full h-auto object-contain border-2 border-black bg-white shadow-[3px_3px_0_rgba(0,0,0,0.2)]"
          />
        </div>
        <div class="min-h-0 flex items-center justify-center">
          <Image
            src={imgSQL50Achievement}
            alt="BIA digital marketing mockup: Meta Ads Manager and Instagram ad creatives"
            class="w-full h-auto object-contain border-2 border-black bg-white shadow-[3px_3px_0_rgba(0,0,0,0.2)]"
          />
        </div>
      </div>
    </div>

    <div class="my-4 h-px bg-black/15"></div>

    <!-- Marketing Analytics -->
    <div class="space-y-6">
      <div class="space-y-4">
        <h2 class="text-2xl sm:text-3xl font-medium leading-tight">
          {marketing_analytics.title}
        </h2>
        <p class="text-sm sm:text-base leading-relaxed">
          {marketing_analytics.summary}
        </p>
      </div>
      <div class="grid gap-6 items-stretch">
        <div class="space-y-0">
          <!-- Marketing analytics syllabus flowchart (HTML/Tailwind) -->
          <div class="flex flex-col items-center p-6">
            <p class="text-base font-normal text-black/80 mb-1">
              Marketing Analytics Syllabus.
            </p>
            <div
              class="border-2 border-black px-6 py-3 font-bold text-base"
              style="background-color:#F3D053"
            >
              Phase 1: Foundation
            </div>
            <div class="w-px h-4 bg-black" aria-hidden="true"></div>
            <div
              class="border-2 border-black bg-white px-6 py-4 text-left text-sm w-full max-w-xl"
            >
              <p><strong>Week 1:</strong> Product-centric NPV</p>
              <p><strong>Week 2:</strong> Customer-centric CLV</p>
              <p><strong>Week 3:</strong> Data Wrangling</p>
            </div>
            <div class="w-px h-4 bg-black" aria-hidden="true"></div>
            <div
              class="border-2 border-black px-6 py-3 font-bold text-base"
              style="background-color:#F3D053"
            >
              Phase 2: Predictive Analytics
            </div>
            <div class="w-px h-4 bg-black" aria-hidden="true"></div>
            <div
              class="border-2 border-black bg-white px-6 py-4 text-left text-sm w-full max-w-xl"
            >
              <p>
                <strong>Week 4:</strong> Segmentation (Unsupervised Learning)
              </p>
              <p><strong>Week 5:</strong> Targeting (Supervised Learning)</p>
            </div>
            <div class="w-px h-4 bg-black" aria-hidden="true"></div>
            <div
              class="border-2 border-black px-6 py-3 font-bold text-base"
              style="background-color:#F3D053"
            >
              Phase 3: Causal Inference
            </div>
            <div class="w-px h-4 bg-black" aria-hidden="true"></div>
            <div
              class="border-2 border-black bg-white px-6 py-4 text-left text-sm w-full max-w-xl"
            >
              <p>
                <strong>Week 6 &amp; 7:</strong> Primary Data &amp; A/B Testing
              </p>
              <p>
                <strong>Week 8:</strong> Endogeneity &amp; Instrumental Variable
              </p>
              <p><strong>Week 9:</strong> Natural Experiment</p>
              <p><strong>Week 10:</strong> Causal Machine Learning</p>
            </div>
          </div>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="flex flex-col gap-6">
            <div class="space-y-3">
              <h3 class="text-xl font-semibold">Results &amp; grades</h3>
              <div class="overflow-x-auto">
                <table
                  class="w-full text-sm border-2 border-black bg-white shadow-[3px_3px_0_rgba(0,0,0,0.2)]"
                >
                  <thead class="bg-black text-white">
                    <tr>
                      <th
                        class="px-3 py-2 text-left font-semibold border-r border-white whitespace-normal break-words"
                      >
                        Assessment
                      </th>
                      <th
                        class="px-3 py-2 text-left font-semibold whitespace-normal break-words"
                      >
                        Grade
                      </th>
                    </tr>
                  </thead>
                  <tbody>
                    {
                      marketing_analytics.results.map((item, index) => (
                        <tr
                          class={
                            index === marketing_analytics.results.length - 1
                              ? "bg-yellow-100/80 font-semibold"
                              : "bg-white"
                          }
                        >
                          <td class="px-3 py-2 border-t border-black/20 align-top whitespace-normal break-words">
                            <p>{item.assessment}</p>
                            {item.focus && item.focus !== "-" && (
                              <p class="text-xs text-black/70 mt-0.5">
                                {item.focus}
                              </p>
                            )}
                          </td>
                          <td class="px-3 py-2 border-t border-black/20 align-top whitespace-normal break-words">
                            {item.grade}
                          </td>
                        </tr>
                      ))
                    }
                  </tbody>
                </table>
              </div>
            </div>

            <div class="space-y-3">
              <h3 class="text-xl font-semibold">Topics covered</h3>
              <ul class="flex flex-wrap gap-2">
                {
                  marketing_analytics.topics.map((topic) => (
                    <li class="border-2 border-black bg-white px-3 py-1.5 text-sm shadow-[3px_3px_0_rgba(0,0,0,0.2)]">
                      {topic}
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
          <div
            class="overflow-hidden min-h-0 flex items-center justify-center bg-transparent"
          >
            <Image
              src={imgMarketingVenn}
              alt="Marketing analytics venn diagram"
              class="w-full h-auto object-contain"
            />
          </div>
        </div>
      </div>
    </div>

    <div class="my-4 h-px bg-black/15"></div>
    <!-- BIA -->
    <div class="space-y-6">
      <div class="space-y-4">
        <h2 class="text-2xl sm:text-3xl font-medium leading-tight">
          {bia.title}
        </h2>
        <div>
          <div
            class="float-left mr-4 w-20 h-20 sm:w-24 sm:h-24 border-2 border-black bg-white flex items-center justify-center overflow-hidden"
          >
            <Image
              src={imgBiaLogo}
              alt=""
              width={96}
              height={96}
              class="w-full h-full object-contain"
            />
          </div>
          <p class="text-sm sm:text-base leading-relaxed">{bia.summary}</p>
          <div class="clear-both"></div>
        </div>
      </div>
      <div class="grid md:grid-cols-[2fr_2fr] gap-6 items-stretch">
        <div
          class="bg-white overflow-hidden min-h-0 flex items-center justify-center"
        >
          <Image
            src={imgBiaMockup}
            alt="BIA digital marketing mockup: Meta Ads Manager and Instagram ad creatives"
            class="w-full h-auto object-contain"
          />
        </div>
        <div class="flex flex-col gap-6">
          <div class="space-y-2">
            <h3 class="text-lg font-semibold">Objectives</h3>
            <p class="space-y-1 text-sm">{bia.objectives}</p>
          </div>
          <div class="space-y-3">
            <h3 class="text-lg font-semibold">Scope</h3>
            <ul class="flex flex-wrap gap-2">
              {
                bia.scope.map((item) => (
                  <li class="border-2 border-black bg-white px-3 py-1.5 text-sm shadow-[3px_3px_0_rgba(0,0,0,0.2)]">
                    {item}
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="space-y-2">
            <h3 class="text-lg font-semibold">Strategy</h3>
            <ul class="space-y-1 text-sm list-disc list-inside">
              {bia.strategy.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="space-y-2">
            <h3 class="text-lg font-semibold">Result</h3>
            {
              bia.result.map((item) => (
                <p class="text-sm border-2 border-black bg-white px-3 py-2 shadow-[3px_3px_0_rgba(0,0,0,0.2)]">
                  {item}
                </p>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <div class="my-4 h-px bg-black/15"></div>

    <!-- E-Cell -->
    <div class="space-y-6">
      <div class="space-y-4">
        <h2 class="text-2xl sm:text-3xl font-medium leading-tight">
          {ecell.title}
        </h2>
        <div>
          <div
            class="float-left mr-4 w-20 h-20 sm:w-24 sm:h-24 border-2 border-black bg-black flex items-center justify-center overflow-hidden"
          >
            <Image
              src={imgEcellLogo}
              alt="E-Cell SAKEC logo"
              width={96}
              height={96}
              class="w-full h-full object-contain"
            />
          </div>
          <p class="text-sm sm:text-base leading-relaxed">{ecell.summary}</p>
          <div class="clear-both"></div>
        </div>
      </div>
      <div class="grid md:grid-cols-[1fr_2fr] gap-6 items-stretch">
        <div
          class="border-2 border-black bg-white shadow-[6px_6px_0_rgba(0,0,0,0.25)] overflow-hidden min-h-0"
        >
          <Image
            src={imgZaikaWebsite}
            alt=""
            class="w-full h-full object-cover aspect-square object-center"
          />
        </div>
        <div class="flex flex-col gap-6">
          <div class="space-y-2">
            <h3 class="text-lg font-semibold">Digital Content Objectives</h3>
            <p class="space-y-1 text-sm">{ecell.objectives}</p>
          </div>
          <div class="space-y-3">
            <h3 class="text-xl font-semibold">The impact.</h3>
            <div class="grid grid-cols-2 gap-3">
              {
                ecell.impact.map((item) => (
                  <div class="relative border-2 border-black bg-white p-3 flex flex-col shadow-[4px_4px_0_rgba(0,0,0,0.25)]">
                    <span class="absolute top-3 right-4 text-3xl text-emerald-500 leading-none">
                      ↑
                    </span>
                    <div class="text-xl mb-1">{item.icon}</div>
                    <p class="text-lg font-semibold leading-none">
                      {item.value}
                    </p>
                    <p class="text-xs mt-1 text-black/80">{item.label}</p>
                  </div>
                ))
              }
