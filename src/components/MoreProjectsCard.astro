---
const base = import.meta.env.BASE_URL;
---

<section class="py-16 px-5 border-t border-gray-200">
  <div class="max-w-5xl mx-auto border-3 border-black bg-white p-8 shadow-[8px_8px_0px_rgba(0,0,0,0.3)] text-center space-y-3">
    <h2 class="text-2xl font-medium">More projects</h2>
    <p class="text-gray-600 text-sm md:text-base">Browse the full list of case studies and builds.</p>
    <a href={`${base}projects/`} class="inline-flex font-semibold underline underline-offset-4">View all projects</a>
  </div>
</section>
