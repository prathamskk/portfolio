---
import { Image } from 'astro:assets';
import Bars from "./Bars.astro"

import svgUnderline from '../../assets/underline.svg'
import arrowCard from '../../assets/arrow-card.svg'

import imgSltArch from '../../assets/projects/slt/slt_system_architecture.png';

const base = import.meta.env.BASE_URL

const work = {
  name: 'Projects',
  desc: `Case studies across data engineering, analytics, full-stack builds, and creative delivery — all in one place.`,
  cover: imgSltArch,
  href: `${base}projects/`,
}
---


<section class="py-25 space-y-10 px-5" id="work">
    <div class="max-w-md mx-auto relative ">
      <h1 class="text-4xl font-medium text-center">My Work</h1>
      <img src={svgUnderline.src} alt="arrow" width="140" class="absolute left-35 -bottom-2" />
    </div>
  
    <div class="max-w-xl mx-auto">
      <a href={work.href} class="flex flex-col bg-white p-5 group relative transition-all duration-200 hover:shadow-[4px_4px_0px_rgba(0,0,0,0.3)]">
          <div class="w-full h-[200px] overflow-hidden border-2">
           <Image src={work.cover} alt="" class="w-full h-full object-cover object-[center_55%]" />
          </div>
          <div class="space-y-1 pt-4">
            <div class="flex pr-2">
              <h2 class="text-xl font-medium flex-1">{work.name}</h2>
              <img src={arrowCard.src} alt="arrow" width="25" />
            </div>
            <p class="mr-20">{work.desc}</p>
          </div>
          <Bars />
        </a>
    </div>
</section>
